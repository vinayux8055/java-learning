class Solution {
    public int maxActiveSectionsAfterTrade(String s) {
        int totalOnes = 0;
        int maxGain = 0;
        int prevZero = Integer.MIN_VALUE;
        int n = s.length();
        int i = 0;
        while (i < n) {
            int j = i;
            while (j < n && s.charAt(j) == s.charAt(i)) {
                j++;
            }
            int len = j - i;

            if (s.charAt(i) == '1') {
                totalOnes += len;
            } else {
                maxGain = Math.max(maxGain, prevZero + len);
                prevZero = len;
            }

            i = j;
        }

        return totalOnes + maxGain;
    }
}
